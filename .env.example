# Local-only defaults. Copy to .env before starting the stack: make init
COMPOSE_PROJECT_NAME=activity-policy-control-plane
DEMO_MODE=true
HOST_BIND=127.0.0.1
ACTIVITY_DB_PATH=backend/data/activity.db

# Application endpoints
BACKEND_PORT=8000
FRONTEND_PORT=5173
PUBLIC_BACKEND_URL=http://localhost:8000
VITE_API_BASE_URL=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_HEALTH_PATH=/healthz
BACKEND_MODULE=app.main:app
BACKEND_COMMAND=
FRONTEND_SCRIPT=dev
FRONTEND_COMMAND=

# PostgreSQL
POSTGRES_DB=activity_policy
POSTGRES_USER=activity
POSTGRES_PASSWORD=activity-local-password
POSTGRES_PORT=5432

# NATS JetStream
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Valkey
VALKEY_PORT=6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio-local-password
MINIO_BUCKET=activity-artifacts
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Keycloak (development bootstrap credentials only)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin-local-password
KEYCLOAK_REALM=activity
KEYCLOAK_PORT=8080

# OpenBao (development mode only; replace with a configured server outside local demos)
OPENBAO_DEV_ROOT_TOKEN=openbao-local-root-token
OPENBAO_PORT=8200

# Optional Ollama policy planner. Leave OLLAMA_API_KEY empty for the deterministic local fallback.
# For Ollama Cloud use https://ollama.com and a model available to your account.
OLLAMA_PORT=11434
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=minimax-m2.5
OLLAMA_TIMEOUT_SECONDS=90
