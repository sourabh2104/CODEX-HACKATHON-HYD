FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/workspace/backend

WORKDIR /workspace
COPY . /workspace

# The repository is intentionally allowed to start in a docs-only state. Once
# backend/ is added, its declared dependencies take precedence; the fallback
# keeps the image useful for a conventional FastAPI app without a lockfile.
RUN set -eux; \
    if [ -f backend/requirements.txt ]; then \
      pip install --no-cache-dir -r backend/requirements.txt; \
    elif [ -f backend/pyproject.toml ]; then \
      pip install --no-cache-dir ./backend; \
    else \
      pip install --no-cache-dir 'fastapi>=0.115,<1' 'uvicorn[standard]>=0.30,<1'; \
    fi

CMD ["bash", "/workspace/scripts/serve-backend.sh"]
